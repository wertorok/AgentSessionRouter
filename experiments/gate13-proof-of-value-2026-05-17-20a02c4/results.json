  },
  "runtime_import_serving_enabled": false,
  "serving_enabled": false,
  "seed_principles": [
    {
      "id": "AMB-RESCUE-0001",
      "statement": "Evaluation and telemetry paths must not affect caller-facing answers; observation must remain separate from production response behavior.",
      "applies": "Apply to shadow evaluation, telemetry, benchmarking, and monitoring paths beside production answer path.",
      "counter": "If caller explicitly requests comparison/evaluation output, expose it as product contract, not hidden telemetry."
    },
    {
      "id": "AMB-RESCUE-0002",
      "statement": "Untrusted or stale evidence must produce an explicit signal and safe fallback, not silent use of stale data.",
      "applies": "Apply to caches, factsheets, session memory, evidence stores, and derived context that can drift.",
      "counter": "If evidence can be fully revalidated before use, signal may remain internal; never silently use unrevalidated evidence."
    },
    {
      "id": "AMB-RESCUE-0003",
      "statement": "Verified evidence artifacts should be the operational source of truth; opaque model or session state must not be the only authority.",
      "applies": "Apply when an agent/router chooses between verified artifacts and opaque conversational state for durable decisions.",
      "counter": "If artifact is stale or lower trust than current source data, revalidate or regenerate before treating it as authority."
    },
    {
      "id": "AMB-RESCUE-0004",
      "statement": "Runtime-served principles need applicability conditions and an explicit rejection or counter-evidence path to avoid dogmatization.",
      "applies": "Apply to durable principles, policies, or memory items that may influence future agent behavior at runtime.",
      "counter": "If a principle lacks applicability and counter-evidence fields, keep it advisory/docs-only and do not serve it as normative runtime memory."
    },
    {
      "id": "AMB-RESCUE-0005",
      "statement": "Durable architectural memory must have diffable provenance; hidden model-memory must not become the authority.",
      "applies": "Apply when architectural memory persists across sessions, projects, agents, or release phases.",
      "counter": "If no diffable artifact or explicit provenance exists, treat memory as transient context only and do not promote or serve it."
    },
    {
      "id": "AMB-DOC-0008",
      "statement": "Classification rubrics should make scoring explicit and auditable by documenting deterministic signals, scoring formulas, rejection rules, and lifecycle/status boundaries without adding runtime evaluation.",
      "applies": "Apply as a generic rubric/scorer design principle for classification pipelines.",
      "counter": "If classification is subjective and lacks auditable deterministic signals, redesign the rubric before treating scores as evidence."
    },
    {
      "id": "AMB-SD-000039",
      "statement": "Orphaned session replacement must remain transparent; dead sessions are never silently reused.",
      "applies": "Apply universally to any session management system.",
      "counter": "Forensic inspection may read dead sessions, but production answering must avoid silently reusing them."
    }
  ],
  "questions": [
    {
      "id": "Q1",
      "principle_ids": [
        "AMB-RESCUE-0001"
      ],
      "question": "Architecture review: a shadow evaluator found that direct_resume beats cluster_consult on one answer. Should the router immediately switch the caller-facing answer to the shadow result inside the same request? Give the decision and reasoning."
    },
    {
      "id": "Q2",
      "principle_ids": [
        "AMB-RESCUE-0002",
        "AMB-RESCUE-0003"
      ],
      "question": "Architecture review: a factsheet selector still exists but the snippet hash changed. It is probably a harmless refactor and serving the cached fact would be faster. Should the router serve it silently, return an internal error to caller, or do something else?"
    },
    {
      "id": "Q3",
      "principle_ids": [
        "AMB-RESCUE-0003"
      ],
      "question": "Architecture review: a lead session remembers that fallback_count is cheap, but the diffable experiment artifact says fallback cost rose after the last refactor. Which source should drive the next decision and what should happen before treating either as authority?"
    },
    {
      "id": "Q4",
      "principle_ids": [
        "AMB-RESCUE-0004"
      ],
      "question": "Architecture review: we want to runtime-serve a new engineering principle, but it has only a statement and provenance. applies_when and counter_evidence are empty. Is it safe to seed it into lead sessions?"
    },
    {
      "id": "Q5",
      "principle_ids": [
        "AMB-RESCUE-0005"
      ],
      "question": "Architecture review: instead of maintaining ENGINEERING_PRINCIPLES.md, we can rely on the durable Claude lead session to remember all architectural lessons. Is hidden session memory enough as the long-term source of truth?"
    },
    {
      "id": "Q6",
      "principle_ids": [
        "AMB-DOC-0008"
      ],
      "question": "Architecture review: a new classifier rejects candidates with a score below 0.6, but the signals, weights, and rejection rules are not documented because the code is short. Is that acceptable before promotion?"
    },
    {
      "id": "Q7",
      "principle_ids": [
        "AMB-SD-000039"
      ],
      "question": "Architecture review: a persisted session record points to a missing Claude .jsonl file. To preserve speed, can production routing keep using the DB session id as if it were alive and only log a warning later?"
    },
    {
      "id": "Q8",
      "principle_ids": [
        "AMB-RESCUE-0002",
        "AMB-RESCUE-0004"
      ],
      "question": "Architecture review: Gate 13 passed one successful smoke test with seeded memory. There is no post-serving continuity benchmark yet, but adversarial BROKEN=0. Should we enable serving now?"
    }
  ],
